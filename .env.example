# --- Telegram Bot Settings ---
# Токен бота от @BotFather
API_TOKEN=8653048232:AAGh9m...

# --- Database Settings ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=wb_monitor_db

# URL для SQLAlchemy.
# ВНИМАНИЕ: 'db' — это имя сервиса в docker-compose.yml. Не меняйте его на localhost при запуске в Docker.
DATABASE_URL=postgresql+asyncpg://postgres:your_password@db:5432/wb_monitor_db

# --- Frontend & Security Settings ---
# Ваш статический домен из панели ngrok для Mini App
NGROK_URL=https://your-domain.ngrok-free.dev

# Список разрешенных адресов для CORS (через запятую без пробелов)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-domain.ngrok-free.dev